    "lint:write": "npx @biomejs/biome check --write",
    "test": "jest",
    "update:adk": "node scripts/update-adk.mjs"
  },
  "devDependencies": {
    "@ainetwork/adk": "file:../ain-adk-v0",
    "@types/jest": "^30.0.0",
    "jest": "^30.0.0",
    "lerna": "^8.2.3",
    "ts-jest": "^29.4.0",
    "tsup": "^8.2.3",
    "typescript": "^5.0.0"
  },
  "license": "MIT"
}
