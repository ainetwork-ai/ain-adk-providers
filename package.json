{
  "name": "ain-adk-providers",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/memory/*",
    "packages/models/*",
    "packages/auth/*",
    "examples/*"
  ],
  "scripts": {
    "build": "lerna run build",
    "clean": "lerna run clean && lerna clean",
    "publish:lerna": "lerna run build && lerna publish --no-private",
